---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
}

const {
  title = 'Petshop Triskel – Tu mascota merece lo mejor',
  description = 'Alimentos, accesorios y shampoos para perros, gatos, peces, conejos y aves en Montevideo. Pedí por WhatsApp y lo llevamos hasta tu puerta.',
  image = 'https://triskel.com/og-image.png', // ← cambiá por tu dominio real
  url = 'https://triskel.com',
  type = 'website',
} = Astro.props;
---

<!-- SEO básico -->
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#4a7c59" />
<link rel="canonical" href={url} />

<!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
<meta property="og:type" content={type} />
<meta property="og:url" content={url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="es_UY" />
<meta property="og:site_name" content="Petshop Triskel" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />