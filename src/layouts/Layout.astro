---
interface Props {
	title: string; 
}

const { title } = Astro.props; 
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Petshop Triskel - Alimentos y accesorios para tus mascotas. Envío a domicilio en Montevideo." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
 
    <!-- Google Fonts: Nunito + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;700;800;900&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
 
    <title>{title}</title>
 
    <style is:global>
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: 'DM Sans', sans-serif;
        background-color: #faf8f4;
        color: #1a411b;
        margin: 0;
        padding: 0;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Nunito', sans-serif;
      }
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #e0f3e0;
      }
      ::-webkit-scrollbar-thumb {
        background: #5bb55c;
        border-radius: 3px;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>